# ==============================================================================
# gemini-cuda - Environment Configuration
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env': cp .env.example .env
# 2. Add your Google AI Studio API key.
# 3. Source it before running: export $(cat .env | xargs)
# ==============================================================================

# Your API Key
GEMINI_API_KEY=your_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------------------------
# Model Selection (Optional)
# ------------------------------------------------------------------------------
# The C++ audit engine will default to 'gemini-1.5-pro' if this is left blank.
# You can override this to test specific frontier models.
#
# Production Reasoning:    gemini-3.1-pro
# Stable Production:       gemini-1.5-pro
# High-Speed Linting:      gemini-1.5-flash
#
GEMINI_MODEL_ID=gemini-3.1-pro
